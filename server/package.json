{
  "name": "kakeibu-server",
  "version": "1.0.0",
  "description": "가계부 백엔드 서버",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx --watch src/app.ts",
    "start": "node dist/app.js",
    "build": "tsc",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio"
  },
  "type": "module",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.0",
    "xlsx": "^0.18.5"
  }
}
